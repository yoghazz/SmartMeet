# Application
APP_NAME=SmartMeet
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://smartmeet:password@localhost:5432/smartmeet_db
SYNC_DATABASE_URL=postgresql://smartmeet:password@localhost:5432/smartmeet_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# Whisper ASR
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu

# MinIO / S3 Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_AUDIO=smartmeet-audio
MINIO_BUCKET_DOCS=smartmeet-docs
MINIO_SECURE=false

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# File limits
MAX_AUDIO_SIZE_MB=500
MAX_RECORDING_HOURS=8
